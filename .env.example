# goSky — сократитель ссылок

# Публичный origin фронтенда (обязательно)
FRONTEND_ORIGIN=http://localhost:5175

# Публичный URL коротких ссылок (продакшен: https://go.skykraft.su)
PUBLIC_BASE_URL=http://localhost:5175

COOKIE_SECURE=false

# PostgreSQL
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/gosky

JWT_SECRET=change-me-in-production

# OAuthSky SSO (единый вход)
OAUTHSKY_ENABLED=true
OAUTHSKY_URL=https://oauth.skykraft.su
# Для Docker prod: http://api:8000
OAUTHSKY_INTERNAL_URL=
OAUTHSKY_CLIENT_ID=gosky
OAUTHSKY_CLIENT_SECRET=change-me
# Callback: {FRONTEND_ORIGIN}/api/auth/oauthsky/callback
OAUTHSKY_REDIRECT_URI=

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000
